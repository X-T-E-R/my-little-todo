{
  "$schema": "https://raw.githubusercontent.com/nicegui-dev/nicegui/main/nicegui/resources/capability.schema.json",
  "identifier": "default",
  "description": "Default capabilities for My Little Todo",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-meta-recursive",
    "shell:allow-open"
  ]
}
